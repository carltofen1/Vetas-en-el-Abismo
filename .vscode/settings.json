{
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": false,
  "files.trimTrailingWhitespace": true,
  "files.encoding": "utf8",
  "[gdscript]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "files.associations": {
    "*.gd": "gdscript",
    "*.tscn": "godot-scene",
    "*.tres": "godot-resource"
  }
}
