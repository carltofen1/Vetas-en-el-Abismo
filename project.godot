; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Vetas Abismales"
config/description="Brawler táctico 2v2 de control territorial en minas subterráneas"
config/version="0.2.0"
run/main_scene="res://scenes/UI/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
config/icon="res://assets/art/ui/icon.svg"

[autoload]

GameManager="*res://scripts/autoloads/GameManager.gd"
SceneLoader="*res://scripts/autoloads/SceneLoader.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
NetworkManager="*res://scripts/autoloads/NetworkManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

